DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=casa

JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

PORT=3000

SENTRY_DSN=

# Swagger fica desligado em producao por padrao. Para usar na VPS, defina
# ENABLE_SWAGGER=true e proteja com usuario/senha fortes.
ENABLE_SWAGGER=false
SWAGGER_USER=
SWAGGER_PASSWORD=

# Disabled by default. Set both values temporarily to generate real test alerts in production.
ENABLE_TEST_ALERTS=false
TEST_ALERT_TOKEN=
