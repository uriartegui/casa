# Copie para deploy/.env na VPS e preencha. NUNCA commite o .env real.

# Domínio público da API (usado pelo Caddy para emitir o certificado HTTPS).
# Pode ser o hostname da HostGator (ex.: vpsbr-XXXXXXXX.vpshostgator.com.br)
# ou um domínio seu apontando para o IP da VPS.
API_DOMAIN=

# Postgres (roda no próprio compose; não fica exposto na internet)
POSTGRES_USER=casa
POSTGRES_DB=casa
POSTGRES_PASSWORD=

# Gere com: openssl rand -hex 32
JWT_SECRET=
