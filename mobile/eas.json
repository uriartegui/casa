{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "submit": {
    "production": {}
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://colmeiaapp.duckdns.org"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://colmeiaapp.duckdns.org"
      }
    },
    "production": {
      "distribution": "store",
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://colmeiaapp.duckdns.org"
      }
    }
  }
}
